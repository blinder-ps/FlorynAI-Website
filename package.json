{
  "name": "floryn-ai-landing",
  "version": "1.0.0",
  "private": true,
  "description": "Secure Floryn AI landing page and enquiry backend",
  "main": "server.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node server.js",
    "dev": "node --watch server.js",
    "check": "node --check server.js && node --check public/script.js && npm run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "compression": "^1.7.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "nodemailer": "^9.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
