NODE_ENV=production
PORT=3000
TRUST_PROXY=1

# SMTP credentials from your email provider.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=replace-with-a-secret

# Use an address permitted by your SMTP provider.
MAIL_FROM=Floryn AI Website <website@florynai.com>
MAIL_TO=info@florynai.com

# Comma-separated production origins, including https://
ALLOWED_ORIGINS=https://florynai.com,https://www.florynai.com
